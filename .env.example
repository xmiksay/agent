# --- Storage ---
DATABASE_URL=postgres://localhost/agent
REPO_BASE_PATH=/var/lib/claude-agent/repos     # working trees: <base>/<service_slug>/<project_slug>/branches/<branch>

# --- Job runtime ---
MAX_CONCURRENT_JOBS=3
LISTEN_ADDR=0.0.0.0:3000

# Externally reachable base URL of this agent. Used to auto-register provider
# webhooks ({PUBLIC_BASE_URL}/webhook/{kind}/{slug}). Leave unset to skip
# auto-registration and wire hooks by hand.
# PUBLIC_BASE_URL=https://agent.example.com

# Per-task soft token budget. Runner pauses claude when cumulative output
# tokens reach 50% of this number, preserving session_id so the operator can
# Resume after the 5-hour rate-limit window resets.
TASK_TOKEN_BUDGET=1000000
# Per-turn wall-clock timeout (seconds). Past it the runner SIGKILLs the agent
# and its whole process group (orphaned test processes included), keeping
# session_id so the operator can Resume. 0 = disabled.
JOB_TIMEOUT_SECS=0
RUST_LOG=agent=info

# --- Runtime environment for the agent (both optional, off by default) ---
# NVM: when set, the agent runs with the node toolchain NVM would activate
# prepended to PATH, honouring each worktree's .nvmrc (else the `default` alias).
# NVM_DIR=/home/agent/.nvm
#
# Per-task PostgreSQL: when PROJECT_DB_ADMIN_URL is set, the runner creates a
# throwaway LOGIN-only role + database per task (agent_task_<id>), exposes it to
# the agent via DATABASE_URL + the PG* vars, and drops both at task end. The
# admin DSN needs CREATE ROLE + CREATE DATABASE privileges.
# PROJECT_DB_ADMIN_URL=postgres://admin:pw@localhost:5432/postgres
# Host:port the agent connects to (defaults to the admin URL's host); override
# when the agent reaches the DB at a different address than the admin connection.
# PROJECT_DB_HOST_FOR_AGENT=localhost:5432

# --- API auth (optional; if unset, /api/* is open) ---
# API_BEARER_TOKEN=long-random-token            # SPA prompts the operator for this
                                               # and stores it in localStorage

# --- Git services ---
# Forge credentials (GitLab, GitHub, …): PAT, webhook secret, base URL, bot
# username are stored in the `service` table. Manage them via
# /api/services.
