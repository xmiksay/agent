# --- Storage ---
DATABASE_URL=postgres://localhost/agent
REPO_BASE_PATH=/var/lib/claude-agent/repos     # working trees: <base>/<service_slug>/<project_slug>/branches/<branch>

# --- Job runtime ---
MAX_CONCURRENT_JOBS=3
LISTEN_ADDR=0.0.0.0:3000

# Externally reachable base URL of this agent. Used to auto-register provider
# webhooks ({PUBLIC_BASE_URL}/webhook/{kind}/{slug}). Leave unset to skip
# auto-registration and wire hooks by hand.
# PUBLIC_BASE_URL=https://agent.example.com

# Per-task soft token budget. Runner pauses claude when cumulative output
# tokens reach 50% of this number, preserving session_id so the operator can
# Resume after the 5-hour rate-limit window resets.
TASK_TOKEN_BUDGET=1000000
RUST_LOG=agent=info

# --- API auth (optional; if unset, /api/* is open) ---
# API_BEARER_TOKEN=long-random-token            # SPA prompts the operator for this
                                               # and stores it in localStorage

# --- Git services ---
# Forge credentials (GitLab, GitHub, …): PAT, webhook secret, base URL, bot
# username are stored in the `git_services` table. Manage them via
# /api/git_services.
